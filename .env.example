# Shared recipe-import token (ADR-0019). Sent as the `X-Shoop-Import` header to
# the `/api/import-recipe` Cloudflare Pages Function and must match the
# `IMPORT_TOKEN` bound to the Pages project (dashboard, Production + Preview).
# This is NOT a real secret — it ships in the client bundle; its only job is to
# drop drive-by scanners. Leave empty here; set the real value in `.env.local`
# (never committed) and in the Cloudflare build env.
VITE_IMPORT_TOKEN=

# Shared nutrition token (ADR-0027). Sent as the `X-Shoop-Nutrition` header to
# the `/api/nutrition` Cloudflare Pages Function and must match the
# `NUTRITION_TOKEN` bound to the Pages project (dashboard, Production + Preview).
# Like VITE_IMPORT_TOKEN this ships in the client bundle and is NOT a real secret;
# it only drops drive-by scanners. Leave empty here; set the real value in
# `.env.local` (never committed) and in the Cloudflare build env.
VITE_NUTRITION_TOKEN=

# USDA FoodData Central API key (ADR-0027) — a REAL secret. Read server-side only
# by the `/api/nutrition` function (env name `FDC_API_KEY`); it is NEVER sent to
# the client or echoed in a response. Leave empty here; bind the real key in the
# Cloudflare Pages project settings (and `.env.local` for local function runs).
FDC_API_KEY=
