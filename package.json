    "@fortawesome/react-fontawesome": "^3.3.1",
    "@huggingface/transformers": "^4.2.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tanstack/react-query": "^5.101.0",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router": "^7.18.0",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@playwright/test": "^1.61.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
